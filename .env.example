# Telegram bot token from @BotFather
TELOXIDE_TOKEN=

# Hamrah account credentials
HAMRAH_PHONE=
HAMRAH_PASSWORD=

# Comma-separated Telegram numeric user ids allowed to use the bot (1-5 admins)
# Tip: send /whoami once to a fresh deployment with your id temporarily added, or use @userinfobot
ADMIN_IDS=

# Optional outbound HTTP proxy for Hamrah API
HAMRAH_PROXY=
